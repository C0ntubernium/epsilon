{
  "name": "localscript",
  "version": "1.0.0",
  "description": "Local agent system for Lua code generation using local LLM",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "localscript": "./bin/localscript.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "lua",
    "llm",
    "agent",
    "codegen",
    "local",
    "ollama",
    "llama.cpp"
  ],
  "author": "LocalScript Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "conf": "^12.0.0",
    "consola": "^3.2.3",
    "execa": "^9.5.2",
    "ink": "^4.4.1",
    "ora": "^8.1.1",
    "sisteransi": "^1.0.5",
    "split-lines": "^3.0.0",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "tree-kit": "^0.8.7",
    "which": "^5.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/which": "^3.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://github.com/localscript/localscript",
  "repository": {
    "type": "git",
    "url": "https://github.com/localscript/localscript"
  }
}